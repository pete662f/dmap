# Used by Android build config for physical-device APKs. Leave unset for
# emulator-only/local backend development.
# DMAP_HOST_IP=192.168.0.195

# Backend containers bind to localhost by default. Use 0.0.0.0 or a LAN IP only
# when a physical device must reach services on this machine.
# DMAP_BIND_HOST=127.0.0.1

# Optional explicit backend overrides:
# DMAP_BACKEND_URL=http://192.168.1.10:8080
# DMAP_SEARCH_BACKEND_URL=http://192.168.1.10:8081
# DMAP_IMAGERY_BACKEND_URL=http://192.168.1.10:8083

# Required only for GeoDanmark Ortofoto tile forwarding. Prefer a token file
# outside the repo tree when possible.
# DMAP_ORTHOFOTO_TOKEN_FILE=/Users/you/.config/dmap2/ortofoto-token
# DMAP_ORTHOFOTO_TOKEN=your-dataforsyningen-token
# DMAP_ORTHOFOTO_TIMEOUT_MS=8000
